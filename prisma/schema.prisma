// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProjectRole {
  LEADER
  SUPERVISOR
  STUDENT
  EXTERNAL
}

enum ProjectStatus {
  STARTING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectMethodology {
  KANBAN
  SCRUM
  SCRUMBAN
  NONE
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  MOVED
  ASSIGNED
  COMMENTED
  JOINED
  LEFT
}

enum ActivityEntity {
  TASK
  PROJECT
  COMMENT
  MEMBER
  BOARD
  SPRINT
  EXPECTED_RESULT
}

enum MemberStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum NotificationType {
  PROJECT_INVITATION
  TASK_ASSIGNED
  COMMENTARY_MENTION
  SYSTEM_ALERT
}

enum ProjectMode {
  CLASSIC
  HYBRID
}

enum ResultStatus {
  NOT_STARTED
  STARTED
  IN_REVIEW
  VALIDATED
  COMPLETED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  googleId  String   @unique
  isAdmin   Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectMembers ProjectMember[]
  assignedTasks  Task[]           @relation("AssignedTasks")
  createdTasks   Task[]           @relation("CreatedTasks")
  comments       Comment[]
  attachments    Attachment[]
  activityLogs   ActivityLog[]
  notifications  Notification[]
  taughtSubjects Subject[]        @relation("SubjectProfessors")
  ownedResults   ExpectedResult[] @relation("ResultOwner")

  @@map("users")
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String             @id @default(cuid())
  name        String
  description String?
  color       String             @default("#3B82F6")
  status      ProjectStatus      @default(ACTIVE)
  methodology ProjectMethodology @default(KANBAN)
  isPublic    Boolean            @default(false)
  isArchived  Boolean            @default(false)

  isInstitutional Boolean @default(false)
  subjectId       String?

  mode            ProjectMode      @default(CLASSIC)
  expectedResults ExpectedResult[]

  githubOwner String?
  githubRepo  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      ProjectMember[]
  boards       Board[]
  sprints      Sprint[]
  tags         Tag[]
  tasks        Task[]
  activityLogs ActivityLog[]
  subject      Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@map("projects")
}

// ─── ProjectMember ───────────────────────────────────────────────────────────

model ProjectMember {
  id       String       @id @default(cuid())
  role     ProjectRole
  status   MemberStatus @default(PENDING)
  joinedAt DateTime     @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  expectedResults ExpectedResult[] @relation("ResultCollaborators")

  @@unique([userId, projectId])
  @@map("project_members")
}

// ─── Board ───────────────────────────────────────────────────────────────────

model Board {
  id       String  @id @default(cuid())
  name     String
  position Int     @default(0)
  color    String?
  wipLimit Int?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("boards")
}

// ─── Sprint ──────────────────────────────────────────────────────────────────

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("sprints")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#888888")

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks TaskTag[]

  @@unique([name, projectId])
  @@map("tags")
}

// ─── Task ─────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  position    Int          @default(0)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  boardId String?
  board   Board?  @relation(fields: [boardId], references: [id], onDelete: SetNull)

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   User?   @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("CreatedTasks", fields: [creatorId], references: [id])

  parentId String?
  parent   Task?   @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("Subtasks")

  tags        TaskTag[]
  comments    Comment[]
  attachments Attachment[]

  expectedResultId String?
  expectedResult   ExpectedResult? @relation(fields: [expectedResultId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

// ─── TaskTag ──────────────────────────────────────────────────────────────────

model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

// ─── Comment ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ─── Attachment ───────────────────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedBy String
  uploader   User   @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── ActivityLog ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String         @id @default(cuid())
  action    ActivityAction
  entity    ActivityEntity
  entityId  String
  meta      Json?
  createdAt DateTime       @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([entityId])
  @@map("activity_logs")
}

// ─── Notifications ───────────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String // El usuario que recibe la notificación
  type      NotificationType
  title     String // Ej: "Nueva invitación de proyecto"
  message   String? // Ej: "Martín te ha invitado a PROJEIC"
  isRead    Boolean          @default(false)
  entityId  String? // ID de referencia (ej: ID del proyecto o tarea)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Ramos de la Universidad (EIC) ──────────────────────────────────────────
model Subject {
  id     String  @id @default(cuid())
  name   String
  code   String?
  period String

  professors User[]    @relation("SubjectProfessors")
  projects   Project[] // Relación uno a muchos: Un ramo tiene muchos proyectos

  @@map("subjects")
}

model ExpectedResult {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      ResultStatus @default(NOT_STARTED)
  progress    Int          @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("ResultOwner", fields: [ownerId], references: [id])

  collaborators ProjectMember[] @relation("ResultCollaborators")

  tasks Task[]

  evidences Evidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history StatusLog[]

  @@map("expected_results")
}

model Evidence {
  id               String         @id @default(cuid())
  url              String? // Link a PR, Figma, Deploy
  fileKey          String? // Referencia a S3/Cloudinary si suben archivos
  type             String // "URL", "IMAGE", "PDF"
  createdAt        DateTime       @default(now())
  expectedResultId String
  expectedResult   ExpectedResult @relation(fields: [expectedResultId], references: [id])
}

model StatusLog {
  id               String         @id @default(cuid())
  expectedResultId String
  result           ExpectedResult @relation(fields: [expectedResultId], references: [id], onDelete: Cascade)

  previousStatus ResultStatus
  newStatus      ResultStatus
  reason         String?      @db.Text
  userId         String
  createdAt      DateTime     @default(now())
}
